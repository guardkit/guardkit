# Weighted-evaluation extension — adversarial config knobs
# Overlays on top of the base langchain-deepagents .env.example.template.
# Shell env vars override agent-config.yaml; YAML overrides DEFAULT_CONFIG.

# Composite-score acceptance threshold (0.0-1.0). Overrides adversarial_config.acceptance_threshold (default: 0.7).
ACCEPTANCE_THRESHOLD=0.7

# Adversarial intensity mode: full | light | solo. Overrides adversarial_config.intensity (default: full).
ADVERSARIAL_INTENSITY=full

# Maximum Player revision attempts (positive integer). Overrides adversarial_config.max_retries (default: 3).
MAX_RETRIES=3
