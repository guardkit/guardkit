"""Domain configuration schema for weighted evaluation.

Defines the GOAL.md / DOMAIN.md schema with weighted evaluation criteria.
Each domain specifies criteria with weights that sum to 1.0.

Template variables:
    {{DomainName}} — Domain identifier

Populated by: TASK-TI-012 (Domain Configuration Schema)
"""

from __future__ import annotations

import re
from dataclasses import dataclass, field
from typing import Any


@dataclass
class EvaluationCriterion:
    """A single weighted evaluation criterion.

    Attributes:
        name: Criterion identifier (e.g., "accuracy", "completeness").
        weight: Weight in the composite score (0.0 to 1.0). All weights must sum to 1.0.
        description: Human-readable description of what this criterion evaluates.
        accept_example: Example of content that passes this criterion.
        reject_example: Example of content that fails this criterion.
        score_range: Valid score range string (e.g., "0.0-1.0" or "1-5").
    """

    name: str
    weight: float
    description: str = ""
    accept_example: str = ""
    reject_example: str = ""
    score_range: str = "0.0-1.0"


@dataclass
class MetadataFieldSchema:
    """Schema definition for a metadata field from GOAL.md table.

    Maps to MetadataField from domain_validator.py at conversion time.
    """

    name: str
    type: str = "string"  # string, integer, float, array, boolean
    valid_values: str = ""  # Raw from table: "enum: [a, b]" or "range: 1-5" or "range: 1+"
    required: bool = False
    description: str = ""


@dataclass
class QualityThresholds:
    """Quality threshold configuration from GOAL.md."""

    minimum_weighted_score: float = 0.7
    required_fields: list[str] = field(default_factory=list)
    format_requirements: list[str] = field(default_factory=list)


@dataclass
class GoalSchema:
    """Schema for a domain's GOAL.md configuration.

    Defines the evaluation criteria, output format, and generation
    guidelines for a specific domain.

    Attributes:
        domain_name: Domain identifier.
        domain_description: What this domain is about.
        criteria: List of weighted evaluation criteria.
        output_schema: JSON schema for Player output.
        generation_guidelines: Instructions for the Player.
        metadata_schema: List of metadata field definitions from GOAL.md table.
        quality_thresholds: Quality threshold configuration.
        generation_target: Description of what the Player agent should generate.
    """

    domain_name: str
    domain_description: str = ""
    criteria: list[EvaluationCriterion] = field(default_factory=list)
    output_schema: dict[str, Any] = field(default_factory=dict)
    generation_guidelines: list[str] = field(default_factory=list)
    metadata_schema: list[MetadataFieldSchema] = field(default_factory=list)
    quality_thresholds: QualityThresholds | None = None
    generation_target: str = ""

    def validate_weights(self) -> bool:
        """Check that criteria weights sum to 1.0 (within tolerance)."""
        if not self.criteria:
            return True
        total = sum(c.weight for c in self.criteria)
        return abs(total - 1.0) < 0.01

    def criteria_as_dict(self) -> dict[str, float]:
        """Return criteria as a name -> weight mapping."""
        return {c.name: c.weight for c in self.criteria}


