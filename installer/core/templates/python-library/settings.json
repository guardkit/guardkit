{
  "schema_version": "1.0.0",
  "naming_conventions": {
    "class": {
      "element_type": "class",
      "pattern": "{{Name}}",
      "case_style": "PascalCase",
      "prefix": null,
      "suffix": ".py",
      "examples": []
    },
    "module": {
      "element_type": "module",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": ".py",
      "examples": [
        "data_loader",
        "config_parser",
        "type_utils"
      ]
    },
    "function": {
      "element_type": "function",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": null,
      "examples": [
        "parse_config",
        "validate_input",
        "build_response"
      ]
    },
    "constant": {
      "element_type": "constant",
      "pattern": "{{NAME}}",
      "case_style": "SCREAMING_SNAKE_CASE",
      "prefix": null,
      "suffix": null,
      "examples": []
    }
  },
  "file_organization": {
    "by_layer": true,
    "by_feature": false,
    "test_location": "separate",
    "max_files_per_directory": 50
  },
  "layer_mappings": {
    "src": {
      "name": "src",
      "directory": "src/{{PackageName}}",
      "namespace_pattern": null,
      "file_patterns": [
        "*.py",
        "!__pycache__/**"
      ]
    },
    "tests": {
      "name": "tests",
      "directory": "tests",
      "namespace_pattern": null,
      "file_patterns": [
        "*.py",
        "test_*.py",
        "conftest.py"
      ]
    }
  },
  "code_style": {
    "indentation": "spaces",
    "indent_size": 4,
    "line_length": 100,
    "trailing_commas": true,
    "type_hints": "required",
    "docstrings": "google_style"
  },
  "generation_options": {
    "preserve_comments": true,
    "preserve_whitespace": true,
    "auto_format": true
  }
}
