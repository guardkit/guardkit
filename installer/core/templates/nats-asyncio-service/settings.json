{
  "schema_version": "1.0.0",
  "naming_conventions": {
    "class": {
      "element_type": "class",
      "pattern": "{{Name}}",
      "case_style": "PascalCase",
      "prefix": null,
      "suffix": ".py",
      "examples": ["DomainService", "ServiceSettings", "OrderRequest", "OrderResponse"]
    },
    "function": {
      "element_type": "function",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": null,
      "examples": [
        "__init__",
        "__main__",
        "app",
        "config"
      ]
    },
    "module": {
      "element_type": "module",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": ".py",
      "examples": [
        "__init__",
        "__main__"
      ]
    },
    "constant": {
      "element_type": "constant",
      "pattern": "{{NAME}}",
      "case_style": "SCREAMING_SNAKE_CASE",
      "prefix": null,
      "suffix": null,
      "examples": ["NATS_URL", "SERVICE_NAME", "DEFAULT_TIMEOUT"]
    }
  },
  "file_organization": {
    "by_layer": true,
    "by_feature": false,
    "test_location": "separate",
    "max_files_per_directory": 50
  },
  "layer_mappings": {
    "Entry Point": {
      "name": "Entry Point",
      "directory": "{{project_name}}/",
      "namespace_pattern": "{{project_name}}",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["Application bootstrap", "Broker initialization", "Handler registration via import side-effects"]
    },
    "Application": {
      "name": "Application",
      "directory": "{{project_name}}/",
      "namespace_pattern": "{{project_name}}",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["FastStream app creation", "Lifespan context manager", "Broker wiring"]
    },
    "Configuration": {
      "name": "Configuration",
      "directory": "{{project_name}}/config.py",
      "namespace_pattern": "{{project_name}}.config",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["Environment variable loading via pydantic-settings", "NATS connection parameters", "Service configuration"]
    },
    "Schemas": {
      "name": "Schemas",
      "directory": "{{project_name}}/schemas/",
      "namespace_pattern": "{{project_name}}.schemas",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["Pydantic message models", "Correlation ID fields", "Request/response schema definitions"]
    },
    "Handlers": {
      "name": "Handlers",
      "directory": "{{project_name}}/handlers/",
      "namespace_pattern": "{{project_name}}.handlers",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["NATS subscriber decorators", "Message dispatch to services", "Pub/sub topic binding"]
    },
    "Services": {
      "name": "Services",
      "directory": "{{project_name}}/services/",
      "namespace_pattern": "{{project_name}}.services",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ],
      "responsibilities": ["Business logic implementation", "Domain operations", "No broker/NATS imports"]
    }
  },
  "code_style": {
    "indentation": "spaces",
    "indent_size": 4,
    "line_length": 88,
    "trailing_commas": true,
    "quote_style": "double",
    "async_preferred": true,
    "type_hints": "required",
    "docstrings": "google",
    "linter": "ruff",
    "formatter": "ruff"
  },
  "generation_options": {
    "preserve_comments": true,
    "preserve_whitespace": true,
    "auto_format": true
  }
}