{
  "schema_version": "1.0.0",
  "naming_conventions": {
    "class": {
      "element_type": "class",
      "pattern": "{{Name}}",
      "case_style": "PascalCase",
      "prefix": null,
      "suffix": ".py",
      "examples": []
    },
    "function": {
      "element_type": "function",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": null,
      "examples": [
        "__init__",
        "__main__",
        "app",
        "config"
      ]
    },
    "module": {
      "element_type": "module",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": ".py",
      "examples": [
        "__init__",
        "__main__"
      ]
    },
    "constant": {
      "element_type": "constant",
      "pattern": "{{NAME}}",
      "case_style": "SCREAMING_SNAKE_CASE",
      "prefix": null,
      "suffix": null,
      "examples": []
    }
  },
  "file_organization": {
    "by_layer": true,
    "by_feature": false,
    "test_location": "separate",
    "max_files_per_directory": 50
  },
  "layer_mappings": {
    "Entry Point": {
      "name": "Entry Point",
      "directory": "{{project_name}}/",
      "namespace_pattern": "{{project_name}}",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Application": {
      "name": "Application",
      "directory": "{{project_name}}/",
      "namespace_pattern": "{{project_name}}",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Configuration": {
      "name": "Configuration",
      "directory": "{{project_name}}/config.py",
      "namespace_pattern": "{{project_name}}.config",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Schemas": {
      "name": "Schemas",
      "directory": "{{project_name}}/schemas/",
      "namespace_pattern": "{{project_name}}.schemas",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Handlers": {
      "name": "Handlers",
      "directory": "{{project_name}}/handlers/",
      "namespace_pattern": "{{project_name}}.handlers",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Services": {
      "name": "Services",
      "directory": "{{project_name}}/services/",
      "namespace_pattern": "{{project_name}}.services",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    }
  },
  "code_style": {
    "indentation": "spaces",
    "indent_size": 4,
    "line_length": 88,
    "trailing_commas": true
  },
  "generation_options": {
    "preserve_comments": true,
    "preserve_whitespace": true,
    "auto_format": true
  }
}