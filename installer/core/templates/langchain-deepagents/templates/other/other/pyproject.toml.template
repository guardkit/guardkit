[project]
name = "deepagents-exemplar"
version = "0.1.0"
description = "DeepAgents exemplar demonstrating two-agent Player-Coach orchestration"
requires-python = ">=3.11"
dependencies = [
    "deepagents>=0.4.11",
    "langchain>=1.2.11",
    "langchain-core>=1.2.18",
    "langgraph>=0.2",
    "langchain-community>=0.3",
    "tavily-python>=0.5",
    "langsmith>=0.2",
    "python-dotenv>=1.0",
    "pyyaml>=6.0",
]

[dependency-groups]
dev = [
    "pytest>=9.0.2",
]
