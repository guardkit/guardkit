        from {{ProjectName}}.search_data import search_data
        from {{ProjectName}}.write_output import write_output

        with patch("{{ProjectName}}.player.create_deep_agent") as mock_cda, \
             patch("{{ProjectName}}.player.FilesystemBackend"):
