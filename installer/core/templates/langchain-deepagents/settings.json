{
  "schema_version": "1.0.0",
  "naming_conventions": {
    "class": {
      "element_type": "class",
      "pattern": "{{Name}}",
      "case_style": "PascalCase",
      "prefix": null,
      "suffix": ".py",
      "examples": []
    },
    "function": {
      "element_type": "function",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": null,
      "examples": [
        "agent",
        "coach",
        "player",
        "coach_prompts",
        "player_prompts"
      ]
    },
    "module": {
      "element_type": "module",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": ".py",
      "examples": [
        "agent",
        "coach"
      ]
    },
    "constant": {
      "element_type": "constant",
      "pattern": "{{NAME}}",
      "case_style": "SCREAMING_SNAKE_CASE",
      "prefix": null,
      "suffix": null,
      "examples": []
    }
  },
  "file_organization": {
    "by_layer": true,
    "by_feature": false,
    "test_location": "separate",
    "max_files_per_directory": 50
  },
  "layer_mappings": {
    "Entrypoint": {
      "name": "Entrypoint",
      "directory": "src/Entrypoint",
      "namespace_pattern": "{{project_name}}.entrypoint",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Agents": {
      "name": "Agents",
      "directory": "src/Agents",
      "namespace_pattern": "{{project_name}}.agents",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Prompts": {
      "name": "Prompts",
      "directory": "src/Prompts",
      "namespace_pattern": "{{project_name}}.prompts",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Tools": {
      "name": "Tools",
      "directory": "src/Tools",
      "namespace_pattern": "{{project_name}}.tools",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Domain Config": {
      "name": "Domain Config",
      "directory": "src/Domain Config",
      "namespace_pattern": "{{project_name}}.domain config",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Runtime Config": {
      "name": "Runtime Config",
      "directory": "src/Runtime Config",
      "namespace_pattern": "{{project_name}}.runtime config",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Tests": {
      "name": "Tests",
      "directory": "src/Tests",
      "namespace_pattern": "{{project_name}}.tests",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    }
  },
  "code_style": {
    "indentation": "spaces",
    "indent_size": 4,
    "line_length": 88,
    "trailing_commas": true
  },
  "generation_options": {
    "preserve_comments": true,
    "preserve_whitespace": true,
    "auto_format": true
  }
}