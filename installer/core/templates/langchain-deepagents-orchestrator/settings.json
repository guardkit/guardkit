{
  "schema_version": "1.0.0",
  "naming_conventions": {
    "class": {
      "element_type": "class",
      "pattern": "{{Name}}",
      "case_style": "PascalCase",
      "prefix": null,
      "suffix": ".py",
      "examples": []
    },
    "function": {
      "element_type": "function",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": null,
      "examples": [
        "agents",
        "orchestrator_tools",
        "agent",
        "evaluator_prompts",
        "orchestrator_prompts"
      ]
    },
    "module": {
      "element_type": "module",
      "pattern": "{{name}}",
      "case_style": "snake_case",
      "prefix": null,
      "suffix": ".py",
      "examples": [
        "agents",
        "orchestrator_tools"
      ]
    },
    "constant": {
      "element_type": "constant",
      "pattern": "{{NAME}}",
      "case_style": "SCREAMING_SNAKE_CASE",
      "prefix": null,
      "suffix": null,
      "examples": []
    }
  },
  "file_organization": {
    "by_layer": true,
    "by_feature": false,
    "test_location": "separate",
    "max_files_per_directory": 50
  },
  "layer_mappings": {
    "Infrastructure": {
      "name": "Infrastructure",
      "directory": "src/Infrastructure",
      "namespace_pattern": "{{project_name}}.infrastructure",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    },
    "Shared": {
      "name": "Shared",
      "directory": "src/Shared",
      "namespace_pattern": "{{project_name}}.shared",
      "file_patterns": [
        "*.py",
        "!*_test.py",
        "!test_*.py"
      ]
    }
  },
  "code_style": {
    "indentation": "spaces",
    "indent_size": 4,
    "line_length": 88,
    "trailing_commas": true
  },
  "generation_options": {
    "preserve_comments": true,
    "preserve_whitespace": true,
    "auto_format": true
  }
}