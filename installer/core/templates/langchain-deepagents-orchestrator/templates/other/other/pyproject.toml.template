[project]
name = "deepagents-orchestrator-exemplar"
version = "0.1.0"
description = "DeepAgents two-model pipeline orchestrator exemplar (reasoning + implementation)"
requires-python = ">=3.11"
dependencies = [
    "deepagents>=0.4.11",
    "langchain>=1.2.11",
    "langchain-core>=1.2.18",
    "langgraph>=0.2",
    "langchain-community>=0.3",
    "langchain-anthropic>=0.2",
    "python-dotenv>=1.0",
    "pyyaml>=6.0",
]

[project.optional-dependencies]
# Every LangChain integration this template can be configured to use MUST appear here.
# See TASK-REV-LES1 / LES1 §3 LCOI — provider swaps happen via orchestrator-config.yaml,
# so all supported providers must be declarable in one install command.
providers = [
    "langchain-openai>=0.2",
    "langchain-google-genai>=2.0",
]

[dependency-groups]
dev = [
    "pytest>=9.0.2",
]
