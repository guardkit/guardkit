# GuardKit worktrees (created by autobuild)
.guardkit/worktrees/

# GuardKit canary worktrees (created by scripts/canary_validation_runner.py
# for TASK-HMIG-009 / TASK-REV-HMIG). Sibling rule to .guardkit/worktrees/:
# registered git worktrees, never source-controlled in the parent repo.
.guardkit/canary-worktrees/

# GuardKit autobuild artifacts (per-task state, not source-controlled).
# Use `.guardkit/autobuild/*` (not trailing `/`) so git keeps walking the
# directory and the audit-grade allow-patterns below for TASK-HMIG-009
# can re-include specific files.
.guardkit/autobuild/*
# Audit-grade canary artefacts for TASK-HMIG-009 are explicit allow-patterns
# (canary-set + results + comparison are committed; per-run artefacts under
# .guardkit/autobuild/TASK-REV-HMIG-canary/<harness>/<task_id>/run_<n>/
# stay gitignored — they contain stdout/stderr that may include logged
# secrets, and they're reproducible from the runner).
!.guardkit/autobuild/TASK-REV-HMIG-canary-set.json
!.guardkit/autobuild/TASK-REV-HMIG-canary-results.json
!.guardkit/autobuild/TASK-REV-HMIG-canary-comparison.md
# Audit-grade feature-run artefacts for TASK-HMIG-010 (same rationale as canary):
# the target picks, per-task results, and analysis stay tracked; any per-task
# run artefacts under .guardkit/autobuild/TASK-REV-HMIG-feature-run/ stay
# gitignored (stdout/stderr may include logged secrets, reproducible from runner).
!.guardkit/autobuild/TASK-REV-HMIG-feature-target.json
!.guardkit/autobuild/TASK-REV-HMIG-feature-results.json

# Rollback audit-trail snapshots (TASK-FIX-RBSS): defensive entry that
# applies to consumer projects without `.guardkit/autobuild/` excluded.
_rollback_archive/

# GuardKit archive (completed feature archives)
.guardkit/archive/

# Graphiti query log (data quality debugging)
.guardkit/graphiti-query-log.jsonl
.guardkit/graphiti-query-log.jsonl.1

# Graphiti seeding state (local-only)
.guardkit/seeding/

