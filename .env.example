# GuardKit Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# DO NOT commit .env to version control
#
# ONLY secrets go here. Infrastructure config is in .guardkit/graphiti.yaml
# See: TASK-REV-D2B5 for why infra config must NOT be in .env

# OpenAI API Key - required when using OpenAI providers
OPENAI_API_KEY=sk-proj-your-key-here

# fleet-memory connection SECRETS (FEAT-MEM-08 cutover). Per TASK-REV-D2B5 only
# secrets live here; the non-secret embedder infra (url/model/dims) is in
# .guardkit/graphiti.yaml. Mirror the live relay: docker inspect fleet-memory-relay.
# Loaded by the fleet-memory MCP server (python -m fleet_memory.mcp) and the
# `guardkit memory` CLI. .env is gitignored and does NOT travel via git.
FLEET_MEMORY_PG_DSN=postgresql://fleet_memory:CHANGEME@whitestocks.tailebf801.ts.net:5433/fleet_memory
FLEET_MEMORY_NATS_URL=nats://fleet-memory:CHANGEME@127.0.0.1:4222
